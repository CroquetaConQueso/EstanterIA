            "body": {
              "mode": "raw",
              "raw": "{\n  \"seccionId\": {{seccionId}},\n  \"codigo\": \"EST-POSTMAN\",\n  \"nombre\": \"Estanteria Postman\",\n  \"descripcion\": \"Estanteria creada desde Postman.\",\n  \"slots\": [\n    { \"slotId\": \"slot_1\", \"orden\": 1, \"productoId\": 1, \"cantidadObjetivo\": 8 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/estanterias"
          }
        },
