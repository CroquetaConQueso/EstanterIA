            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"codigoInterno\": \"PROD-POSTMAN\",\n  \"nombre\": \"Producto Postman\",\n  \"descripcion\": \"Producto creado desde Postman.\",\n  \"vincularProveedorDemo\": true,\n  \"stockDisponible\": true\n}"
            },
            "url": "{{baseUrl}}/api/productos"
          }
        }
      ]
    },
    {
      "name": "Vision e Inspecciones",
