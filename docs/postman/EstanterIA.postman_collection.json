            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/api/inspecciones"
          }
        },
        {
          "name": "Detalle inspeccion",
          "request": {
            "method": "GET",
