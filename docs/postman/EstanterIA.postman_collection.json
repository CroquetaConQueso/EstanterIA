            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipoTarea\": \"REPOSICION\",\n  \"prioridad\": \"MEDIA\",\n  \"titulo\": \"Tarea manual Postman\",\n  \"descripcion\": \"Validacion manual desde Postman.\",\n  \"seccionId\": {{seccionId}},\n  \"estanteriaId\": null,\n  \"slotConfiguracionId\": null,\n  \"trabajadorAsignadoId\": null,\n  \"fechaLimite\": null\n}"
            },
