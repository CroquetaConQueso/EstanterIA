            "url": "{{baseUrl}}/api/empresas/EMP-DEMO/planos"
          }
        },
        {
          "name": "Obtener plano operativo",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenAdmin}}" }],
            "url": "{{baseUrl}}/api/planos/{{planoCodigo}}/operativo"
          }
        },
        {
          "name": "Crear plano",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"empresaCodigo\": \"EMP-DEMO\",\n  \"codigo\": \"PLANO-POSTMAN\",\n  \"nombre\": \"Plano Postman\",\n  \"descripcion\": \"Plano creado desde Postman.\",\n  \"ancho\": 1200,\n  \"alto\": 700,\n  \"zonas\": [],\n  \"estanterias\": []\n}"
            },
            "url": "{{baseUrl}}/api/planos"
          }
        },
        {
          "name": "Actualizar plano",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenAdmin}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Plano Postman actualizado\",\n  \"descripcion\": \"Actualizacion desde Postman.\",\n  \"ancho\": 1200,\n  \"alto\": 700,\n  \"zonas\": [],\n  \"estanterias\": []\n}"
            },
            "url": "{{baseUrl}}/api/planos/PLANO-POSTMAN"
          }
        }
      ]
    },
    {
